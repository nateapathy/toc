# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/toc_tracker"

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth app credentials (console.cloud.google.com)
# Scopes needed: openid, email, profile
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Dedicated Gmail account for Scholar alert forwarding
# Create a service account OR use OAuth credentials for this inbox
# Easiest: OAuth credentials for the forwarding Gmail account
SCHOLAR_GMAIL_ADDRESS="your-alerts-inbox@gmail.com"
SCHOLAR_GMAIL_REFRESH_TOKEN="refresh-token-for-alerts-inbox"
